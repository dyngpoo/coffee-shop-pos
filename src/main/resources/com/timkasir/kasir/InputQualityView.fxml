<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.InputQualityController" 
            style="-fx-background-color: #f5f5f5;">
    
    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color: #fff; -fx-border-color: #c99862; -fx-border-width: 0 0 2 0;"
              alignment="CENTER_LEFT" spacing="20" prefHeight="80">
            <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
            
            <Button text="☰" style="-fx-font-size: 25; -fx-background-color: transparent;"/>
            <Label text="Selamat Datang, Barista" style="-fx-font-size: 24; -fx-text-fill: #3b2314;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="timeLabel" style="-fx-background-color: #d3aa78; -fx-padding: 10 20; -fx-border-radius: 30;"/>
        </HBox>
    </top>
    
    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: rgba(55,28,10,0.88); -fx-min-width: 260;" spacing="0" prefWidth="260">
            <padding><Insets all="20"/></padding>
            <VBox alignment="CENTER" spacing="10">
                <Label text="CoffeeShop" style="-fx-font-size: 22; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Label text="Brew Your Moments" style="-fx-font-size: 12; -fx-text-fill: white;"/>
            </VBox>
            <Separator style="-fx-padding: 20 0;"/>
            <VBox spacing="8">
                <Button text="✓ Input Quality" style="-fx-text-fill: white; -fx-background-color: #d3aa78;"/>
                <Button text="🛒 Tambah Keranjang" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="🧮 Hitung Total" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="💵 Bayar" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="💾 Simpan Transaksi" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="🖨️ Cetak Struk" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="📦 Lihat Stok Barang" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="🚪 Logout" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #fff;" VBox.vgrow="ALWAYS">
            <padding><Insets all="30"/></padding>
            
            <Label text="INPUT QUALITY PRODUK" style="-fx-font-size: 32; -fx-text-fill: #3b2314; -fx-font-weight: bold;"/>
            
            <!-- FILTER CONTAINER -->
            <HBox spacing="20" fx:id="filterContainer">
                <VBox spacing="8">
                    <Label text="Tanggal" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #3b2314;"/>
                    <DatePicker fx:id="filterDate" style="-fx-padding: 10; -fx-font-size: 14;"/>
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Produk" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #3b2314;"/>
                    <ComboBox fx:id="filterProduct" style="-fx-padding: 10; -fx-font-size: 14;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Quality" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #3b2314;"/>
                    <ComboBox fx:id="filterQuality" style="-fx-padding: 10; -fx-font-size: 14;"/>
                </VBox>
            </HBox>
            
            <!-- TABLE -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <TableView fx:id="qualityTable" style="-fx-font-size: 14; -fx-border-color: #3b2314;">
                    <columns>
                        <TableColumn text="No" prefWidth="60"/>
                        <TableColumn text="Tanggal" prefWidth="120" fx:id="dateColumn"/>
                        <TableColumn text="Produk" prefWidth="200" fx:id="productColumn"/>
                        <TableColumn text="Quality" prefWidth="150" fx:id="qualityColumn"/>
                        <TableColumn text="Keterangan" prefWidth="200" fx:id="descColumn"/>
                    </columns>
                </TableView>
            </ScrollPane>
            
            <!-- NOTES AREA -->
            <VBox spacing="8">
                <Label text="Catatan" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #3b2314;"/>
                <TextArea fx:id="notesArea" prefHeight="100" style="-fx-padding: 15; -fx-font-size: 14;"/>
            </VBox>
            
            <!-- BUTTONS -->
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="BATAL" style="-fx-padding: 12 40; -fx-font-size: 14; -fx-text-fill: #3b2314;" 
                        onAction="#cancel"/>
                <Button text="SIMPAN" style="-fx-padding: 12 40; -fx-font-size: 14; -fx-background-color: #3b2314; -fx-text-fill: white;"
                        onAction="#save"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>