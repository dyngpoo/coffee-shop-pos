<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DashboardController" 
            style="-fx-background-color: #f5f5f5;">
    
    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color: #fff; -fx-border-color: #c99862; -fx-border-width: 0 0 2 0;"
              alignment="CENTER_LEFT" spacing="20" prefHeight="80">
            <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
            
            <Button text="☰" style="-fx-font-size: 25; -fx-background-color: transparent;" 
                    onAction="#toggleMenu" fx:id="mobileMenuBtn"/>
            
            <VBox>
                <Label text="Selamat Datang," style="-fx-font-size: 24; -fx-text-fill: #3b2314;"/>
                <Label text="Kasir" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
            </VBox>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="timeLabel" style="-fx-background-color: #d3aa78; -fx-padding: 10 20; -fx-border-radius: 30; -fx-font-size: 14;"/>
        </HBox>
    </top>
    
    <!-- LEFT SIDEBAR -->
    <left>
        <VBox fx:id="sidebar" style="-fx-background-color: rgba(55,28,10,0.88); -fx-min-width: 260;" 
              spacing="0" prefWidth="260">
            <padding><Insets all="20"/></padding>
            
            <!-- LOGO -->
            <VBox alignment="CENTER" spacing="10">
                <ImageView fitHeight="70" fitWidth="70" preserveRatio="true" fx:id="logoImage"/>
                <Label text="CoffeeShop" style="-fx-font-size: 22; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Label text="Brew Your Moments" style="-fx-font-size: 12; -fx-text-fill: white;"/>
            </VBox>
            
            <Separator style="-fx-padding: 20 0;"/>
            
            <!-- MENU -->
            <VBox spacing="8">
                <Button text="☕ Pilih Produk" style="-fx-text-fill: white; -fx-background-color: #d3aa78;" 
                        onAction="#goToDashboard"/>
                <Button text="✓ Input Quality" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#goToInputQuality"/>
                <Button text="🛒 Tambah Keranjang" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#goToCart"/>
                <Button text="🧮 Hitung Total" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#goToHitungTotal"/>
                <Button text="💵 Bayar" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#goToPayment"/>
                <Button text="💾 Simpan Transaksi" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#goToSaveTransaction"/>
                <Button text="🖨️ Cetak Struk" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#goToPrintReceipt"/>
                <Button text="📦 Lihat Stok Barang" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#goToStock"/>
                <Separator style="-fx-padding: 10 0;"/>
                <Button text="🚪 Logout" style="-fx-text-fill: white; -fx-background-color: transparent;"
                        onAction="#logout"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #fff;" VBox.vgrow="ALWAYS">
            <padding><Insets all="30"/></padding>
            
            <Label text="PILIH PRODUK" style="-fx-font-size: 32; -fx-text-fill: #3b2314; -fx-font-weight: bold;"/>
            
            <!-- SEARCH BAR -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="searchInput" promptText="Cari Produk" style="-fx-padding: 10; -fx-font-size: 14;" 
                           prefWidth="500"/>
                <Button text="🔍" onAction="#searchProduct"/>
            </HBox>
            
            <!-- CATEGORY BUTTONS -->
            <HBox spacing="10" fx:id="categoryBox">
                <Button text="Semua" style="-fx-padding: 10 20; -fx-font-size: 14;" onAction="#filterAll"/>
                <Button text="Coffee" style="-fx-padding: 10 20; -fx-font-size: 14;" onAction="#filterCoffee"/>
                <Button text="Non Coffee" style="-fx-padding: 10 20; -fx-font-size: 14;" onAction="#filterNonCoffee"/>
                <Button text="Tea" style="-fx-padding: 10 20; -fx-font-size: 14;" onAction="#filterTea"/>
                <Button text="Snack" style="-fx-padding: 10 20; -fx-font-size: 14;" onAction="#filterSnack"/>
            </HBox>
            
            <!-- PRODUCTS GRID -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <GridPane fx:id="productsGrid" hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>
                </GridPane>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>