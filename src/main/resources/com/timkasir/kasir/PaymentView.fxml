<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PaymentController" 
            style="-fx-background-color: #f5f5f5;">
    
    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color: #fff; -fx-border-color: #c99862; -fx-border-width: 0 0 2 0;"
              alignment="CENTER_LEFT" spacing="20" prefHeight="80">
            <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
            
            <Button text="☰" style="-fx-font-size: 25; -fx-background-color: transparent;"/>
            <Label text="Selamat Datang, Barista" style="-fx-font-size: 24; -fx-text-fill: #3b2314;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="timeLabel" style="-fx-background-color: #d3aa78; -fx-padding: 10 20;"/>
        </HBox>
    </top>
    
    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: rgba(55,28,10,0.88); -fx-min-width: 260;" spacing="0" prefWidth="260">
            <padding><Insets all="20"/></padding>
            <VBox alignment="CENTER" spacing="10">
                <Label text="CoffeeShop" style="-fx-font-size: 22; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Label text="Brew Your Moments" style="-fx-font-size: 12; -fx-text-fill: white;"/>
            </VBox>
            <Separator style="-fx-padding: 20 0;"/>
            <VBox spacing="8">
                <Button text="💵 Bayar" style="-fx-text-fill: white; -fx-background-color: #d3aa78;"/>
                <Button text="💾 Simpan Transaksi" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="🖨️ Cetak Struk" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="📦 Lihat Stok Barang" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="🚪 Logout" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #fff;" VBox.vgrow="ALWAYS">
            <padding><Insets all="30"/></padding>
            
            <Label text="PEMBAYARAN" style="-fx-font-size: 32; -fx-text-fill: #3b2314; -fx-font-weight: bold;"/>
            
            <!-- TWO COLUMN LAYOUT -->
            <HBox spacing="30" style="-fx-max-width: 1000;">
                
                <!-- LEFT: RINGKASAN -->
                <VBox style="-fx-background-color: #fdf3e7; -fx-padding: 30; -fx-border-radius: 25; -fx-min-width: 400;">
                    <Label text="RINGKASAN" style="-fx-font-size: 24; -fx-text-fill: #3b2314; -fx-font-weight: bold; -fx-padding: 0 0 25 0;"/>
                    
                    <HBox spacing="20" style="-fx-padding: 10 0;">
                        <Label text="Subtotal:" style="-fx-font-size: 18; -fx-text-fill: #3b2314;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="subtotalLabel" text="Rp 0" style="-fx-font-size: 18; -fx-text-fill: #3b2314;"/>
                    </HBox>
                    
                    <HBox spacing="20" style="-fx-padding: 10 0;">
                        <Label text="Diskon:" style="-fx-font-size: 18; -fx-text-fill: #3b2314;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="discountLabel" text="Rp 0" style="-fx-font-size: 18; -fx-text-fill: #3b2314;"/>
                    </HBox>
                    
                    <HBox spacing="20" style="-fx-padding: 10 0;">
                        <Label text="Pajak:" style="-fx-font-size: 18; -fx-text-fill: #3b2314;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="taxLabel" text="Rp 0" style="-fx-font-size: 18; -fx-text-fill: #3b2314;"/>
                    </HBox>
                    
                    <HBox spacing="20" style="-fx-padding: 25 0 0 0; -fx-border-color: #3b2314; -fx-border-width: 2 0 0 0;">
                        <Label text="Total:" style="-fx-font-size: 24; -fx-text-fill: #3b2314; -fx-font-weight: bold; -fx-padding: 15 0 0 0;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalLabel" text="Rp 0" style="-fx-font-size: 24; -fx-text-fill: #3b2314; -fx-font-weight: bold; -fx-padding: 15 0 0 0;"/>
                    </HBox>
                </VBox>
                
                <!-- RIGHT: PEMBAYARAN FORM -->
                <VBox style="-fx-background-color: #fdf3e7; -fx-padding: 30; -fx-border-radius: 25; -fx-min-width: 400;" spacing="20">
                    <Label text="PEMBAYARAN" style="-fx-font-size: 24; -fx-text-fill: #3b2314; -fx-font-weight: bold;"/>
                    
                    <VBox spacing="8">
                        <Label text="Metode Pembayaran" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #3b2314;"/>
                        <ComboBox fx:id="paymentMethod" style="-fx-padding: 12 15; -fx-font-size: 16; -fx-min-width: 350;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Tunai"/>
                                    <String fx:value="QRIS"/>
                                    <String fx:value="Debit"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </VBox>
                    
                    <VBox spacing="8">
                        <Label text="Dibayar" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #3b2314;"/>
                        <TextField fx:id="paidAmount" promptText="Jumlah dibayar" style="-fx-padding: 12 15; -fx-font-size: 16;" onKeyReleased="#calculateChange"/>
                    </VBox>
                    
                    <VBox spacing="8">
                        <Label text="Kembalian" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #3b2314;"/>
                        <TextField fx:id="changeAmount" promptText="Rp. 0" style="-fx-padding: 12 15; -fx-font-size: 16;" editable="false"/>
                    </VBox>
                    
                    <Button text="PROSES PEMBAYARAN" style="-fx-padding: 15; -fx-font-size: 18; -fx-background-color: #371c0a; -fx-text-fill: white; -fx-font-weight: bold;" 
                            onAction="#processPayment"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>