<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CartController" 
            style="-fx-background-color: #f5f5f5;">
    
    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color: #fff; -fx-border-color: #c99862; -fx-border-width: 0 0 2 0;"
              alignment="CENTER_LEFT" spacing="20" prefHeight="80">
            <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
            
            <Button text="☰" style="-fx-font-size: 25; -fx-background-color: transparent;"/>
            <Label text="Selamat Datang, Barista" style="-fx-font-size: 24; -fx-text-fill: #3b2314;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="timeLabel" style="-fx-background-color: #d3aa78; -fx-padding: 10 20;"/>
        </HBox>
    </top>
    
    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: rgba(55,28,10,0.88); -fx-min-width: 260;" spacing="0" prefWidth="260">
            <padding><Insets all="20"/></padding>
            <VBox alignment="CENTER" spacing="10">
                <Label text="CoffeeShop" style="-fx-font-size: 22; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Label text="Brew Your Moments" style="-fx-font-size: 12; -fx-text-fill: white;"/>
            </VBox>
            <Separator style="-fx-padding: 20 0;"/>
            <VBox spacing="8">
                <Button text="🛒 Tambah Keranjang" style="-fx-text-fill: white; -fx-background-color: #d3aa78;"/>
                <Button text="🧮 Hitung Total" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="💵 Bayar" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="💾 Simpan Transaksi" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="🖨️ Cetak Struk" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="📦 Lihat Stok Barang" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
                <Button text="🚪 Logout" style="-fx-text-fill: white; -fx-background-color: transparent;"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #fff;" VBox.vgrow="ALWAYS">
            <padding><Insets all="30"/></padding>
            
            <Label text="TAMBAH KERANJANG" style="-fx-font-size: 32; -fx-text-fill: #3b2314; -fx-font-weight: bold;"/>
            
            <!-- CART TABLE -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <TableView fx:id="cartTable" style="-fx-font-size: 14; -fx-border-color: #3b2314;">
                    <columns>
                        <TableColumn text="Produk" prefWidth="250" fx:id="productColumn"/>
                        <TableColumn text="Harga" prefWidth="120" fx:id="priceColumn"/>
                        <TableColumn text="Qty" prefWidth="150" fx:id="qtyColumn"/>
                        <TableColumn text="Subtotal" prefWidth="150" fx:id="subtotalColumn"/>
                        <TableColumn text="Aksi" prefWidth="100" fx:id="actionColumn"/>
                    </columns>
                </TableView>
            </ScrollPane>
            
            <!-- SUMMARY BOX -->
            <VBox style="-fx-background-color: #fdf3e7; -fx-padding: 30; -fx-border-radius: 20;">
                <HBox spacing="30">
                    <Label text="Total:" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
                    <Label fx:id="totalLabel" text="Rp 0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #3b2314;"/>
                </HBox>
            </VBox>
            
            <!-- CHECKOUT BUTTON -->
            <Button text="CHECKOUT" style="-fx-padding: 15; -fx-font-size: 18; -fx-background-color: #371c0a; -fx-text-fill: white; -fx-font-weight: bold;" 
                    prefWidth="600" onAction="#checkout"/>
        </VBox>
    </center>
</BorderPane>