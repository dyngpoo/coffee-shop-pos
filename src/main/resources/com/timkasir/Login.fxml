<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="529.0" prefWidth="885.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            
            fx:controller="com.timkasir.LoginController">

    <children>

        <!-- LEFT PANEL -->
        <AnchorPane prefHeight="529.0" prefWidth="431.0"
                    style="-fx-background-color: linear-gradient(to bottom right, #4b240f, #1f0d05);">

            <children>

                <!-- background coffee image -->
                <ImageView fitHeight="529.0" fitWidth="431.0"
                           opacity="0.35"
                           preserveRatio="false">
                    <image>
                        <!-- GANTI DENGAN PATH GAMBAR -->
                        <Image url="@images/coffee_bg.png"/>
                    </image>
                </ImageView>

                <!-- Logo -->
                <VBox alignment="CENTER"
                      layoutX="74.0"
                      layoutY="78.0"
                      spacing="10.0">

                    <children>

                        <Label text="☕"
                               textFill="#c79a63">
                            <font>
                                <Font size="60"/>
                            </font>
                        </Label>

                        <Label text="CoffeeShop"
                               textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="28"/>
                            </font>
                        </Label>

                        <Label text="Brew Your Moments"
                               textFill="WHITE">
                            <font>
                                <Font size="22"/>
                            </font>
                        </Label>

                        <Separator prefWidth="290"
                                   style="-fx-background-color: #c79a63;"/>
                    </children>
                </VBox>

                <!-- coffee image -->
                <ImageView fitHeight="250.0"
                           fitWidth="300.0"
                           layoutX="60.0"
                           layoutY="250.0"
                           preserveRatio="true">
                    <image>
                        <!-- GANTI DENGAN PATH GAMBAR -->
                        <Image url="@images/coffee_cup.png"/>
                    </image>
                </ImageView>

            </children>
        </AnchorPane>

        <!-- RIGHT PANEL -->
        <AnchorPane layoutX="431.0"
                    prefHeight="529.0"
                    prefWidth="454.0"
                    style="-fx-background-color: #f5f5f5;">

            <children>

                <!-- title -->
                <VBox alignment="CENTER"
                      layoutX="77.0"
                      layoutY="50.0"
                      prefWidth="300.0"
                      spacing="10.0">

                    <children>

                        <Label text="Login"
                               textFill="#3b1d0d">
                            <font>
                                <Font name="System Bold" size="42"/>
                            </font>
                        </Label>

                        <HBox alignment="CENTER"
                              spacing="10">

                            <children>

                                <Separator prefWidth="80"/>
                                <Label text="☕"
                                       textFill="#b1743f">
                                    <font>
                                        <Font size="18"/>
                                    </font>
                                </Label>
                                <Separator prefWidth="80"/>

                            </children>
                        </HBox>

                        <Label text="Masuk Untuk Mengakses Dashboard"
                               textFill="#b1743f">
                            <font>
                                <Font size="18"/>
                            </font>
                        </Label>

                    </children>
                </VBox>

                <!-- Form -->
                <VBox layoutX="56.0"
                      layoutY="190.0"
                      prefWidth="340.0"
                      spacing="18.0">

                    <children>

                        <!-- Username -->
                        <VBox spacing="8">

                            <children>

                                <Label text="Username"
                                       textFill="#2d1b10">
                                    <font>
                                        <Font size="16"/>
                                    </font>
                                </Label>

                                <HBox alignment="CENTER_LEFT"
                                      prefHeight="40"
                                      style="-fx-background-color: white; -fx-border-color: #b5b5b5; -fx-border-radius: 8; -fx-background-radius: 8;">

                                    <children>

                                        <Label text="👤"
                                               style="-fx-padding: 0 10 0 10;">
                                            <font>
                                                <Font size="18"/>
                                            </font>
                                        </Label>

                                        <TextField promptText="Masukan Username"
                                                   prefHeight="40"
                                                   prefWidth="280"
                                                   style="-fx-background-color: transparent; -fx-border-color: transparent;"

                                                   fx:id="usernameField"/>

                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                        <!-- Password -->
                        <VBox spacing="8">

                            <children>

                                <Label text="Password"
                                       textFill="#2d1b10">
                                    <font>
                                        <Font size="16"/>
                                    </font>
                                </Label>

                                <HBox alignment="CENTER_LEFT"
                                      prefHeight="40"
                                      style="-fx-background-color: white; -fx-border-color: #b5b5b5; -fx-border-radius: 8; -fx-background-radius: 8;">

                                    <children>

                                        <Label text="🔒"
                                               style="-fx-padding: 0 10 0 10;">
                                            <font>
                                                <Font size="18"/>
                                            </font>
                                        </Label>

                                        <PasswordField promptText="Masukan Password"
                                                       prefHeight="40"
                                                       prefWidth="240"
                                                       style="-fx-background-color: transparent; -fx-border-color: transparent;"
                                                        
                                                        fx:id="passwordField"/>

                                        <Button text="👁"
                                                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                        <!-- Remember Me -->
                        <CheckBox text="Ingat Saya"
                                  selected="true"
                                  textFill="#3b1d0d"/>

                        <!-- Login Button -->
                        <Button prefHeight="40"
                                prefWidth="230"
                                style="-fx-background-color: #4b240f;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 10;
                                       -fx-font-size: 16;
                                       -fx-font-weight: bold;"
                                text="Masuk ->"
                                
                                onAction="#handleLogin"/>

                    </children>

                    <padding>
                        <Insets top="10"/>
                    </padding>

                </VBox>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>