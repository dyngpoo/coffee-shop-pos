<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.timkasir.controller.LoginController"
      prefWidth="900" prefHeight="560"
      styleClass="login-root">

    <!-- ══ KIRI: background + overlay + logo ══ -->
    <StackPane HBox.hgrow="ALWAYS">

        <!-- Layer 1: background foto -->
        <ImageView preserveRatio="false"
                   fitWidth="500" fitHeight="560"
                   smooth="true">
            <image>
                <Image url="@/com/timkasir/images/coofe.png"/>
            </image>
        </ImageView>

        <!-- Layer 2: overlay gelap -->
        <Pane style="-fx-background-color: rgba(45,25,10,0.55);"/>

        <!-- Layer 3: logo & teks -->
        <VBox alignment="TOP_CENTER" spacing="8"
              style="-fx-padding: 40 20 20 20;">
            <ImageView fitWidth="80" preserveRatio="true">
                <image>
                    <Image url="@/com/timkasir/images/logo2.png"/>
                </image>
            </ImageView>
            <Label text="CoffeeShop"        styleClass="login-brand-title"/>
            <Label text="Brew Your Moments" styleClass="login-brand-sub"/>
        </VBox>

    </StackPane>

    <!-- ══ KANAN: form login ══ -->
    <StackPane prefWidth="420" styleClass="login-right">
        <VBox alignment="CENTER" spacing="0"
              maxWidth="320" styleClass="login-box">

            <Label text="Login"
                   styleClass="login-title"/>
            <Label text="Masuk Untuk Mengakses Dashboard"
                   styleClass="login-subtitle"/>

            <!-- Username -->
            <VBox spacing="5" styleClass="login-field-group">
                <Label text="Username" styleClass="login-label"/>
                <HBox styleClass="login-input-box" alignment="CENTER_LEFT">
                    <Label text="👤" styleClass="login-icon"/>
                    <TextField fx:id="tfUsername"
                               promptText="Masukan Username"
                               styleClass="login-input"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Password -->
            <VBox spacing="5" styleClass="login-field-group">
                <Label text="Password" styleClass="login-label"/>
                <HBox styleClass="login-input-box" alignment="CENTER_LEFT">
                    <Label text="🔒" styleClass="login-icon"/>
                    <PasswordField fx:id="pfPassword"
                                  promptText="Masukan Password"
                                  styleClass="login-input"
                                  HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Error -->
            <Label fx:id="lblError" text=""
                   styleClass="login-error"
                   visible="false" wrapText="true" maxWidth="280"/>

            <!-- Tombol Login -->
            <Button fx:id="btnLogin" text="Masuk >"
                    maxWidth="Infinity"
                    styleClass="btn-login"
                    onAction="#doLogin">
                <VBox.margin><Insets top="15"/></VBox.margin>
            </Button>

            <!-- Footer -->
            <Label text="© 2026 CoffeeShop" styleClass="login-footer">
                <VBox.margin><Insets top="15"/></VBox.margin>
            </Label>

        </VBox>
    </StackPane>

</HBox>